# Firebase — récupère ces valeurs dans la console Firebase
# Paramètres du projet > Général > Tes applications > Config SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=     # ex: ton-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps (optionnel, utilisé par MapScreen)
VITE_MAPS_API_KEY=
